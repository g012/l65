local function instruction_length(opcode)
    if length_three[opcode] then return 3 end
    if length_two[opcode] then return 2 end
    return 1
end

local bin = cpu.genbin()
local symbols = cpu.symbols
local function byte_at(address)
    return bin[address + 1]
end
local function check(condition, message, ...)
    assert(condition, string.format(message, ...))
end

local expansion_expected = {
    0x3e, 0x91, 0xe0, 0x40,
    0x21, 0x23, 0xc1,
    0x3e, 0x12, 0x22, 0x3e, 0x34, 0x22,
    0x01, 0x02, 0x00, 0x00,
}
local expansion_address = symbols.operator_expansion_test
check(symbols.operator_expansion_end - expansion_address == #expansion_expected,
    'operator expansion test has size %d, expected %d',
    symbols.operator_expansion_end - expansion_address, #expansion_expected)
for i, expected in ipairs(expansion_expected) do
    check(byte_at(expansion_address + i - 1) == expected,
        'operator expansion byte %d is %02X, expected %02X', i,
        byte_at(expansion_address + i - 1), expected)
end

local length_expected = {
    0x0e, 0x05,
    0x0e, 0x05,
    0xf8, 0x05,
    0xf8, 0x05,
}
local length_address = symbols.length_expression_test
check(symbols.length_expression_end - length_address == #length_expected,
    'length expression test has size %d, expected %d',
    symbols.length_expression_end - length_address, #length_expected)
for i, expected in ipairs(length_expected) do
    check(byte_at(length_address + i - 1) == expected,
        'length expression byte %d is %02X, expected %02X', i,
        byte_at(length_address + i - 1), expected)
end

local base_count = 0
for opcode = 0, 0xff do
    if not invalid_base[opcode] then
        base_count = base_count + 1
        local name = string.format('op_%02x', opcode)
        local address = symbols[name]
        check(byte_at(address) == opcode, '%s emitted %02X, expected %02X',
            name, byte_at(address), opcode)
        local next_address = symbols.mnemonic_end
        for next_opcode = opcode + 1, 0xff do
            if not invalid_base[next_opcode] then
                next_address = symbols[string.format('op_%02x', next_opcode)]
                break
            end
        end
        check(next_address - address == instruction_length(opcode),
            '%s has size %d, expected %d', name, next_address - address,
            instruction_length(opcode))
    end
end
check(base_count == 245, 'validated %d base opcodes, expected 245', base_count)

for opcode = 0, 0xff do
    local name = string.format('cb_%02x', opcode)
    local address = symbols[name]
    local next_address = opcode == 0xff and symbols.cb_end
        or symbols[string.format('cb_%02x', opcode + 1)]
    check(byte_at(address) == 0xcb and byte_at(address + 1) == opcode,
        '%s emitted %02X %02X, expected CB %02X', name,
        byte_at(address), byte_at(address + 1), opcode)
    check(next_address - address == 2, '%s has size %d, expected 2',
        name, next_address - address)
end

for index, opcode in ipairs(operator_opcodes) do
    local name = string.format('alt_%02x', opcode)
    local address = symbols[name]
    local next_opcode = operator_opcodes[index + 1]
    local next_address = next_opcode and symbols[string.format('alt_%02x', next_opcode)]
        or symbols.operator_end
    check(byte_at(address) == opcode, '%s emitted %02X, expected %02X',
        name, byte_at(address), opcode)
    check(next_address - address == instruction_length(opcode),
        '%s has size %d, expected %d', name, next_address - address,
        instruction_length(opcode))
end

writebin(filename .. '.gb', bin)
print(string.format('validated %d base, 256 CB, and %d operator encodings',
    base_count, #operator_opcodes))
print(stats)
