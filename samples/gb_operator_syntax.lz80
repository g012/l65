@operator_end

-- Bracketed memory remains available to historical bit mnemonics.
    bit 3,[hl]
    res 3,[hl]
    set 3,[hl]

-- Immediate operator expansions and newline-separated memory destinations.
@operator_expansion_test
    local expansion_value = 0x91
    a := !(expansion_value or 0x80)
    [LCDC] := a

    local function expanded_address() return 0xc123 end
    hl := !expanded_address()

    local expansion_bytes = { 0x12, 0x34 }
    for i = 1, #expansion_bytes do
        a := !expansion_bytes[i]
        [hl+] := a
    end

    bc := !#expansion_bytes
    nop
@operator_expansion_end

-- Lua's length operator remains available inside immediate operands. In
-- mnemonic syntax the first # marks the immediate and the second is Lua's
-- length operator; operator syntax needs only the Lua #.
local length_value = "hello"
@length_expression_test
    ld c, ##length_value
    c := #length_value
    ld hl, sp+##length_value
    hl := sp+#length_value
@length_expression_end

-- These are deliberately declared after their operator-syntax uses.
high_later = 0xff42
absolute_later = 0xc123
sp_offset_later = 4

-- Validate opcode bytes and instruction sizes inside the sample itself.
