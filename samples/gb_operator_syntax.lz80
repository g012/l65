require'gb'

assert(LCDC_DEFAULT == (LCDC_ON | LCDC_BLOCK01 | LCDC_BG_ON))
assert(PAD_A == 0x01 and PAD_DOWN == 0x80)
assert((RP_ENABLE | RP_WRITE_HIGH) == 0xc1)
assert(OAM_SIZE == OBJ_SIZE * OAM_COUNT)
assert(TILEMAP_AREA == TILEMAP_WIDTH * TILEMAP_HEIGHT)

mappers.ROM{ title = "LZ80 OPS", entry = "main" }

section{ "rom", org = 0x0150 }
@main
    jr main

-- Every valid unprefixed SM83 opcode, in opcode order.
-- The 11 lock-up opcodes are intentionally omitted.

@op_00
    nop                      -- 00
@op_01
    ld bc,#0x1234            -- 01
@op_02
    ld (bc),a                -- 02
@op_03
    inc bc                   -- 03
@op_04
    inc b                    -- 04
@op_05
    dec b                    -- 05
@op_06
    ld b,#0x12               -- 06
@op_07
    rlca                     -- 07
@op_08
