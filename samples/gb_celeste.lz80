    bc--
    a := [bc]
    e := a
    bc++
    a := [bc]
    d := a
    a += 8
    [hl+] := a
    a := e
    [hl+] := a
    a := 0x9a
    [hl+] := a
    a := 0x00
    [hl+] := a

    a := d
    a += 16
    [hl+] := a
    a := e
    [hl+] := a
    a := 0x9a
    [hl+] := a
    a := 0x00
    [hl+] := a

    a := d
    a += 24
    [hl+] := a
    a := e
    [hl+] := a
    a := 0x9a
    [hl+] := a
    a := 0x00
    [hl+] := a

    a := d
    a -= 3
    cp #0x49
    jr.c tfuncclinenokill
    a := 0x48
@tfuncclinenokill
    [bc] := a
    a := h
    [temp4+1] := a
    a := l
    [temp4] := a
    pop de
    pop bc
    ret

@@tfuncflag
    a := 0
    [tempx] := a
    [tempy] := a
    push bc
    bc--
    bc--
    push bc
    a := 0x40
    [bc] := a
    bc++
    bc++
    bc++
    bc++
    bc++
    a := [bc]
    cp #10
    jr.nc tfuncflagspr1
    a := 0x76
    jr tfuncflagsprdone
@tfuncflagspr1
    cp #20
    jr.nc tfuncflagspr2
    a := 0x77
    jr tfuncflagsprdone
@tfuncflagspr2
    a := 0x78
@tfuncflagsprdone
    e := a
    a := [bc]
    a++
    cp #30
    jr.nz tfuncflagnoreset
    a := 0
@tfuncflagnoreset
    [bc] := a
    bc--
    a := e
    [bc] := a
    pop hl
    call collidepthing
    cp #0
    jr.z tfuncflagnocoll
    a := [flagmode]
    cp #0
    jr.nz tfuncflagnocoll
    a++
    [flagmode] := a
@tfuncflagnocoll
    pop bc
    ret


@schkSTART

@@playsfx_lowpri
    a := [pl2musp+1]
    cp #0
    jr.z playsfx_lowpri_ok
    a := [pl2musp]
    cp #((sfx_dash_pl) & 0xff)
    jr.z playsfx_lowpri_ok
    cp #((sfx_jump) & 0xff)
    jr.z playsfx_lowpri_ok
    cp #((sfx_walljump) & 0xff)
    jr.z playsfx_lowpri_ok
    ret
@playsfx_lowpri_ok
    call playsfx_pulse
    ret

@@apuenable
    a := 0
    [NR30] := a
    hl := triwave
    bc := 0xff30
    e := 16
@apuwriteloop
    a := [hl]
    hl++
    [bc] := a
    bc++
    e--
    a := e
    cp #0
    jr.nz apuwriteloop
    a := 0x80
    [NR52] := a
    a := 0xFF
    [NR51] := a
    a := 0x77
    [NR50] := a
    a := 0x80
    [NR30] := a
    ret

@@mussetpulse1
    -- read in 3 bytes from [DE]
    -- they are a note to be activated
    -- returns new length counter in a
    a := [de]
    srl a
    srl a
    srl a
    a &= 7
    -- high 3 bits of pd
    a |= 0x80
    h := a
    a := [de]
    de++
    sla a
    sla a
    sla a
    sla a
    sla a
    l := a
    a := [de]
    srl a
    srl a
    srl a
    a |= l
    [NR13] := a
    a := [de]
    swap a
    sla a
    a &= 0xc0
    [NR11] := a
    a := [de]
    de++
    swap a
    sla a
    sla a
    sla a
    a &= 0x80
    l := a
    a := [de]
    srl a
    a &= 0x70
    a |= l
    [NR12] := a
    a := h
    [NR14] := a
    a := [de]
    de++
    a &= 31
    hl := lengthtbl
    a += l
    l := a
    a := 0
    adc a,h
    h := a
    a := [hl]
    ret

@@mussetpulse2
    a := [de]
    srl a
    srl a
    srl a
    a &= 7
    -- high 3 bits of pd
    a |= 0x80
    h := a
    a := [de]
    de++
    sla a
    sla a
    sla a
    sla a
    sla a
    l := a
    a := [de]
    srl a
    srl a
    srl a
    a |= l
    [NR23] := a
    a := [de]
    swap a
    sla a
    a &= 0xc0
    [NR21] := a
    a := [de]
    de++
    swap a
    sla a
    sla a
    sla a
    a &= 0x80
    l := a
    a := [de]
    srl a
    a &= 0x70
    a |= l
    [NR22] := a
    a := h
    [NR24] := a
    a := [de]
    de++
    a &= 31
    hl := lengthtbl
    a += l
    l := a
    a := 0
    adc a,h
    h := a
    a := [hl]
    ret

@@mussettri
    -- read in 3 bytes from [DE]
    -- they are a note to be activated
    -- returns new length counter in a
    a := [de]
    srl a
    srl a
    srl a
    a &= 7
    -- high 3 bits of pd
    h := a
    a := [de]
    de++
    sla a
    sla a
    sla a
    sla a
    sla a
    l := a
    a := [de]
    srl a
    srl a
    srl a
    a |= l
    [NR33] := a
    a := [de]
    de++
    swap a
    sla a
    sla a
    sla a
    a &= 0x80
    l := a
    a := [de]
    srl a
    a &= 0x70
    a |= l
    -- tri correct
    sla a
    --add a, $18
    [NR32] := a
    a := h
    [NR34] := a
    a := [de]
    de++
    a &= 31
    hl := lengthtbl
    a += l
    l := a
    a := 0
    adc a,h
    h := a
    a := [hl]
    ret


@@mussetnsm
    a := [nsxlleft]
    cp #0
    jr.z mussetns
    ret

@mussetns
    de++
    a := [de]
    sla a
    a &= 0xf0
    -- other fields not implemented
    [NR43] := a
    a := [de]
    de++
    swap a
    sla a
    sla a
    sla a
    a &= 0x80
    l := a
    a := [de]
    srl a
    a &= 0x70
    a |= l
    [NR42] := a
    a := 0x80
    [NR44] := a
    a := [de]
    de++
    a &= 31
    hl := lengthtbl
    a += l
    l := a
    a := 0
    adc a,h
    h := a
    a := [hl]
    ret





@@musstep
    a := 5
    [temp] := a
@mussteploop
    b := ((musstate) >> 8)
    a := [temp]
    a--
    sla a
    sla a
    a += 2
    c := a
    push bc
    a := [bc] -- get lleft
    a--
    [bc] := a
    cp #0
    jr.nz musstepnotdone
    bc--
    a := [bc]
    cp #0
    jr.z musstepdisa
    d := a
    bc--
    a := [bc]
    e := a
    push bc
    a := [de]
    a &= 0xc0
    cp #0
    jr.nz musstepnoend
@musstepBP
    bc++
    a := 0
    [bc] := a
    pop bc

    jr musstepdisa
@musstepnoend
    a := [temp]
    a--
    hl := mussetslo
    -- this could break if alignment is bad
    -- so we check that at compile time
    b := 0
    c := a
    hl += bc
    a := [hl]
    b := 0
    c := mussetshi - mussetslo
    hl += bc
    b := a
    a := [hl]
    h := a
    a := b
    l := a
    call jphl
    pop bc
    bc++
    bc++
    [bc] := a
    bc--
    a := d
    [bc] := a
    bc--
    a := e
    [bc] := a
@musstepdisa
@musstepnotdone
    -- avoid channels getting desynced
    pop bc
    a := [bc]
    cp #1
    jr.nz musstepnoprep
    bc--
    a := [bc]
    cp #0
    jr.z musstepnoprep
    d := a
    bc--
    a := [bc]
    e := a
    a := [de]
    a &= 0xc0
    cp #0
    jr.nz musstepnoprep
    bc++
    a := 0
    [bc] := a
@musstepnoprep
    a := [temp]
    a--
    [temp] := a
    cp #0
    jr.nz mussteploop
    ret

@@musseq
    a := 5
    [temp] := a
    bc := musstate+1
    de := musstateseq
@musseqloop
    a := [bc]
    cp #0
    jr.z musseqtryagain
    de++
    jr musseqnoread
@musseqtryagain
    a := [de]
    de++
    l := a
    a := [de]
    cp #0
    jr.z musseqnoread
    h := a
    push bc
    a := [hl+]
    c := a
    a := [hl+]
    b := a
    cp #0
    jr.nz musseqnoloop
@musseqBP
    a := c
    cp #0
    jr.nz musseqdoloop
    pop bc
    jr musseqnoread
@musseqdoloop
    sla a
    a += 1
    cpl
    c := a
    a := 0xff
    b := a
    hl += bc
    pop bc
    a := h
    [de] := a
    de--
    a := l
    [de] := a
    jr musseqtryagain
@musseqnoloop
    a := h
    [de] := a
    de--
    a := l
    [de] := a
    de++
    de++
    push bc
    pop hl
    pop bc
    a := h
    [bc] := a
    bc--
    a := l
    [bc] := a
    bc++
    bc++
    a := 1
    [bc] := a
    bc++
    bc++
    bc++
    jr musseqdone
@musseqnoread
    de++
    bc++
    bc++
    bc++
    bc++
@musseqdone
    a := [temp]
    a--
    [temp] := a
    cp #0
    jr.nz musseqloop
    ret

@@playsfx_pulse
    -- sfx in hl
    a := l
    [pl2musp] := a
    a := h
    [pl2musp+1] := a
    a := 1
    [pl2lleft] := a
    ret

@@playsfx_noise
    -- sfx in hl
    a := l
    [nsxmusp] := a
    a := h
    [nsxmusp+1] := a
    a := 1
    [nsxlleft] := a
    ret

@@playsong
    -- index in a
    sla a
    c := a
    b := 0
    hl := songsp1
    hl += bc
    a := [hl+]
    [pl1seq] := a
    a := [hl]
    [pl1seq+1] := a
    hl := songstr
    hl += bc
    a := [hl+]
    [triseq] := a
    a := [hl]
    [triseq+1] := a
    hl := songsns
    hl += bc
    a := [hl+]
    [nsseq] := a
    a := [hl]
    [nsseq+1] := a
    a := 0x80
    [NR34] := a
    a := ((quick_end) & 0xff)
    [pl1musp] := a
    [nsmusp] := a
    [trimusp] := a
    a := ((quick_end) >> 8)
    [pl1musp+1] := a
    [nsmusp+1] := a
    [trimusp+1] := a
    a := 1
    [pl1lleft] := a
    [nslleft] := a
    [trilleft] := a

    ret

@schkEND

@@copybytes
-- hl destination
-- de source
-- bc count
@copybytesloop
    a := [de]
    [hl+] := a
    de++
    bc--
    a := b
    a |= c
    jr.nz copybytesloop
    ret

-- padding to fit alignment constraints

section{ "mussetslo", align = 0x100 }
    dc.b ((mussetpulse1) & 0xff)
    dc.b ((mussetpulse2) & 0xff)
    dc.b ((mussettri) & 0xff)
    dc.b ((mussetnsm) & 0xff)
    dc.b ((mussetns) & 0xff)

@mussetshi
    dc.b ((mussetpulse1) >> 8)
    dc.b ((mussetpulse2) >> 8)
    dc.b ((mussettri) >> 8)
    dc.b ((mussetnsm) >> 8)
    dc.b ((mussetns) >> 8)


