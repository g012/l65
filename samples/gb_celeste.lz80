-- pico-8 notes
-- * 21 -> mus0_pulse0
-- * 10 -> mus0_ns0 (mus0_triangle0)
-- * 22 -> mus0_pulse1
-- * 12 -> mus0_triangle1
-- * 11 -> mus0_pulse2
-- * 18 -> mus0_triangle2
-- * 19 -> mus0_pulse3
-- * 20 -> mus0_ns1
-- * 17 -> mus0_pulse4
-- title screen song
--   56 -> mus1_pulse0
--   58 -> mus1_triangle0
--   60 -> mus1_ns0
--   57 -> mus1_pulse1
--   58 -> mus1_triangle1
-- song2
--   42 -> mus2_triangle0
--   39 -> mus2_ns0
--   41 -> mus2_pulse0
--   43 -> mus2_triangle1
--   47 -> mus2_ns1
--   44 -> mus2_pulse1
--   45 -> mus2_triangle2
--   46 -> mus2_ns2
--   48 -> mus2_pulse2
--   52 -> mus2_triangle3
--   49 -> mus2_pulse3
--   53 -> mus2_triangle4
--   50 -> mus2_pulse4
-- song3
--	24 -> mus3_pulse0
--	25 -> mus3_triangle0
--   26 -> mus3_ns0
--   28 -> mus3_triangle1
--   27 -> mus3_pulse1
--   29 -> mus3_triangle2
--   31 -> mus3_pulse2
--   33 -> mus3_triangle3
--   30 -> mus3_pulse3
--   34 -> mus3_triangle4
--   36 -> mus3_triangle5
--   32 -> mus3_pulse4
-- sound effects:
-- 0 * death
-- 1 * normal jump
-- 2 * wall jump
-- 3 * dash
-- 4 * begin player spawn (?)
-- 5 x player spawn landed
-- 6 - recovered dash with balloon
-- 7 - balloon or fall floor respawned
-- 8 * boing
-- 9 x try to dash unsuccessfully
-- 13 * berry collected
-- 14 - flying berry leaving
-- 15 - break fall floor
-- 16 - break fake wall, or open chest
-- 23 * key collected
-- 35 - text readout
-- 37 - open big chest
-- 38 * game started
-- 51 - orb collected
-- 54 * dash recovered
-- 55 - flag collect

pb16_unpacker()

writebin(filename..'.gb')
local mussets_lo_address = op_resolve("mussetslo")
local mussets_hi_address = op_resolve("mussetshi")
assert((mussets_lo_address >> 8) == (mussets_hi_address >> 8))
assert(((mussets_hi_address + mussets_hi_address - mussets_lo_address) >> 8)
    == (mussets_hi_address >> 8))
writesym(filename..'.sym', 'rgbds')
print(stats)
