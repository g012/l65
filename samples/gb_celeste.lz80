@@chrdata_pb16
    byte(packed_chrdata)

section{ "mapdata", align = 0x100 }
    byte(read_asset("gb_celeste_map.dat"))

local function note_raw(pitch, duty, volume, length)
    byte((pitch >> 5) | 0x40,
        ((pitch & 0x1f) << 3) | (duty << 1) | (volume >> 3),
        ((volume & 0x07) << 5) | length)
end

local function note(pitch, duty, volume, length)
    if length < 9 then length = length - 1
    elseif length % 8 == 0 then length = 6 + length // 8
    elseif length == 12 then length = 22
    elseif length == 18 then length = 23
    elseif length == 36 then length = 24
    elseif length == 60 then length = 25
    elseif length == 42 then length = 26
    elseif length == 102 then length = 27
    else error("invalid note length") end
    note_raw(pitch, duty, volume, length)
end

local function endnote() byte(0, 0, 0) end

